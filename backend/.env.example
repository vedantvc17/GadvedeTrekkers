# ─────────────────────────────────────────────────────────────────
#  Gadvede Trekkers — Backend Environment Variables
#  Copy this file to backend/.env and fill in real values.
#  Never commit backend/.env to version control.
# ─────────────────────────────────────────────────────────────────

PORT=4000

# Supabase project credentials (found in Supabase Dashboard → Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin API key — must match VITE_ADMIN_API_KEY in frontend .env / Netlify vars
ADMIN_API_KEY=

# Comma-separated list of allowed CORS origins.
# Production domains (gadvede.com) are always allowed in code regardless of
# this value — so enquiry capture never breaks if this is misconfigured.
# Add localhost here only for local development.
CORS_ORIGIN=http://localhost:5173,https://gadvede.com,https://www.gadvede.com
