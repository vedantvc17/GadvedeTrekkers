{
  "info": {
    "name": "Gadvede Trekkers — Full System API",
    "_postman_id": "gt-trek-system-v1",
    "description": "Complete API collection for Gadvede Trekkers management system.\nCovers: Customers · Bookings · Transactions · Events · Vendors · VendorCosts · Employees · Assignments · Availability · Expenses · Reimbursements · Earnings · Dashboard\n\n**Base URL variable:** Set {{base_url}} = http://localhost:3000/api\n**Auth:** Set {{token}} after login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",    "value": "http://localhost:3000/api", "type": "string" },
    { "key": "token",       "value": "",  "type": "string" },
    { "key": "customer_id", "value": "",  "type": "string" },
    { "key": "booking_id",  "value": "",  "type": "string" },
    { "key": "event_id",    "value": "",  "type": "string" },
    { "key": "vendor_id",   "value": "",  "type": "string" },
    { "key": "employee_id", "value": "",  "type": "string" },
    { "key": "expense_id",  "value": "",  "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { pm.collectionVariables.set('token', pm.response.json().token); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@gadvedetrekkers.com\",\n  \"password\": \"admin123\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] },
            "description": "Authenticate and receive JWT token. Token is auto-saved to {{token}} variable."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{token}}\"\n}" },
            "url": { "raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth","refresh"] }
          }
        }
      ]
    },

    {
      "name": "👤 Customers",
      "item": [
        {
          "name": "Create Customer",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('customer_id', pm.response.json().data.id); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Vedant Gadvede\",\n  \"phone\": \"9876543210\",\n  \"email\": \"vedant@example.com\",\n  \"address\": \"Pune, Maharashtra\",\n  \"date_of_birth\": \"1998-05-15\"\n}"
            },
            "url": { "raw": "{{base_url}}/customers", "host": ["{{base_url}}"], "path": ["customers"] },
            "description": "Register a new customer. Phone must be unique."
          }
        },
        {
          "name": "Get All Customers",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/customers?page=1&limit=20&search=", "host": ["{{base_url}}"], "path": ["customers"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"},{"key":"search","value":""}] },
            "description": "List customers with pagination + optional name/phone/email search."
          }
        },
        {
          "name": "Get Customer by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/customers/{{customer_id}}", "host": ["{{base_url}}"], "path": ["customers","{{customer_id}}"] }
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"new@example.com\",\n  \"address\": \"Mumbai, Maharashtra\"\n}" },
            "url": { "raw": "{{base_url}}/customers/{{customer_id}}", "host": ["{{base_url}}"], "path": ["customers","{{customer_id}}"] }
          }
        },
        {
          "name": "Get Customer Bookings",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/customers/{{customer_id}}/bookings", "host": ["{{base_url}}"], "path": ["customers","{{customer_id}}","bookings"] }
          }
        }
      ]
    },

