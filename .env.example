# ─────────────────────────────────────────────────────────────────
#  Gadvede Trekkers — Frontend Environment Variables
#  Copy this file to .env for local development.
#  For production (Netlify), set these in:
#    Netlify Dashboard → Site Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# Full URL of the Express backend (no trailing slash).
# Local dev example : http://localhost:4000
# Production example: https://api.yourdomain.com
VITE_API_BASE_URL=https://your-backend-domain.com

# Admin API key — must match ADMIN_API_KEY in backend/.env
# Required for admin dashboard enquiry fetch (useEnquiries hook).
# Without this, the admin panel falls back to localStorage data only.
VITE_ADMIN_API_KEY=
